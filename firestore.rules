rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== Super Admin 列表 ====================
    // 喺下面 [] 入面加其他 Super Admin 嘅 email，用逗號分隔
    function isSuperAdmin() {
      return request.auth != null 
        && request.auth.token.email in [
          'kermit.tam@gmail.com'
        ];
    }
    
    // 檢查是否為資源擁有者
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ==================== Tabs Collection ====================
    match /tabs/{tabId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isSuperAdmin()
        ||
        (resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid)
        ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['averageRating', 'ratingCount', 'totalRating', 'likes', 'viewCount'])
      );
      allow delete: if request.auth != null && (
        isSuperAdmin()
        ||
        (resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid)
      );
    }

    // ==================== Songs Collection ====================
    match /songs/{songId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isSuperAdmin()
        ||
        (resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid)
        ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['averageRating', 'ratingCount', 'totalRating', 'likes', 'viewCount'])
      );
      allow delete: if request.auth != null && (
        isSuperAdmin()
        ||
        (resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid)
      );
    }

    // ==================== Artists Collection ====================
    match /artists/{artistId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ==================== Users Collection ====================
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (
        isOwner(userId) || isSuperAdmin()
      );
    }

    // ==================== Comments Collection ====================
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && (
        isOwner(resource.data.userId) || isSuperAdmin()
      );
    }

    // ==================== TabRequests Collection ====================
    match /tabRequests/{requestId} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }

    // ==================== System Playlists Collection ====================
    match /playlists/{playlistId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ==================== Settings Collection ====================
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ==================== Page Views ====================
    match /pageViews/{viewId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if false;
    }

    // ==================== Daily Stats ====================
    match /dailyStats/{dateId} {
      allow read, write: if request.auth != null && isSuperAdmin();
    }

    // ==================== Recent Views ====================
    match /recentViews/{docId} {
      allow read: if request.auth != null && isOwner(resource.data.userId);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwner(resource.data.userId);
    }

    // ==================== Rating System ====================
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null && isOwner(request.resource.data.userId);
      allow update, delete: if request.auth != null && isOwner(resource.data.userId);
    }

    // ==================== User Playlists ====================
    match /userPlaylists/{playlistId} {
      allow read: if true;
      allow create: if request.auth != null && isOwner(request.resource.data.userId);
      allow update, delete: if request.auth != null && isOwner(resource.data.userId);
    }

    // ==================== Liked Songs ====================
    match /userLikedSongs/{docId} {
      allow read: if request.auth != null && isOwner(resource.data.userId);
      allow create: if request.auth != null && isOwner(request.resource.data.userId);
      allow delete: if request.auth != null && isOwner(resource.data.userId);
      allow update: if false;
    }

  }
}
