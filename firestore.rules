// Firestore Security Rules
// 去 Firebase Console → Firestore Database → 規則貼上以下內容

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tabs collection (legacy - migrated to songs)
    match /tabs/{tabId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
        ) || (
          request.auth != null 
          && (
            request.auth.token.email == 'kermit.tam@gmail.com'
            || 
            (resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid)
          )
        );
      allow delete: if request.auth != null 
        && (
          request.auth.token.email == 'kermit.tam@gmail.com'
          || 
          (resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid)
        );
    }

    // Songs collection (主樂譜集合)
    match /songs/{songId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if (
          // 允許更新 viewCount 和 rating 相關欄位
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'averageRating', 'ratingCount', 'totalRating'])
        ) || (
          request.auth != null 
          && (
            request.auth.token.email == 'kermit.tam@gmail.com'
            || 
            (resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid)
          )
        );
      allow delete: if request.auth != null 
        && (
          request.auth.token.email == 'kermit.tam@gmail.com'
          || 
          (resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid)
        );
    }
    
    // Artists collection
    match /artists/{artistId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null 
        && (
          request.auth.uid == userId 
          || request.auth.token.email == 'kermit.tam@gmail.com'
        );
    }
    
    // Comments collection
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null 
        && request.auth.uid == resource.data.userId;
    }
    
    // TabRequests collection
    match /tabRequests/{requestId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    
    // Playlists collection (系統歌單 - 管理員管理)
    match /playlists/{playlistId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // ===== NEW: User Playlists (用戶自建歌單) =====
    match /userPlaylists/{playlistId} {
      // 所有人可讀取（用於分享）
      allow read: if true;
      
      // 登入用戶可創建
      allow create: if request.auth != null 
        && request.auth.uid == request.resource.data.userId;
      
      // 只有歌單擁有者可更新
      allow update: if request.auth != null 
        && request.auth.uid == resource.data.userId;
      
      // 只有歌單擁有者可刪除
      allow delete: if request.auth != null 
        && request.auth.uid == resource.data.userId;
    }
    
    // ===== NEW: User Liked Songs (用戶喜愛歌曲) =====
    match /userLikedSongs/{docId} {
      // 用戶可讀取自己的喜愛列表
      allow read: if request.auth != null 
        && (
          resource.data.userId == request.auth.uid
          || resource == null // 允許查詢不存在的文檔
        );
      
      // 登入用戶可創建自己的喜愛記錄
      allow create: if request.auth != null 
        && request.auth.uid == request.resource.data.userId;
      
      // 只有本人可刪除
      allow delete: if request.auth != null 
        && request.auth.uid == resource.data.userId;
    }
    
    // ===== NEW: Ratings (用戶評分) =====
    match /ratings/{ratingId} {
      // 所有人可讀取評分
      allow read: if true;
      
      // 登入用戶可創建評分
      allow create: if request.auth != null 
        && request.auth.uid == request.resource.data.userId;
      
      // 只有評分者可更新自己的評分
      allow update: if request.auth != null 
        && request.auth.uid == resource.data.userId;
      
      // 只有評分者可刪除
      allow delete: if request.auth != null 
        && request.auth.uid == resource.data.userId;
    }
    
    // Settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Page Views collection
    match /pageViews/{viewId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if false;
    }
    
    // Daily Stats collection
    match /dailyStats/{dateId} {
      allow read: if request.auth != null 
        && request.auth.token.email == 'kermit.tam@gmail.com';
      allow write: if request.auth != null 
        && request.auth.token.email == 'kermit.tam@gmail.com';
    }
    
    // Recent Views collection (用戶瀏覽記錄)
    match /recentViews/{docId} {
      allow read: if request.auth != null 
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
        && request.auth.uid == resource.data.userId;
    }
  }
}
