// Firestore Security Rules
// 去 Firebase Console → Firestore Database → 規則貼上以下內容

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 評分系統 - 任何人可讀，登入用戶可寫
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // 用戶歌單 - 公開可讀，只有創建者可修改
    match /userPlaylists/{playlistId} {
      allow read: if true;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // 喜愛歌曲 - 只有本人可讀寫
    match /userLikedSongs/{docId} {
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // 歌曲資料 - 允許更新評分欄位
    match /tabs/{tabId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['averageRating', 'ratingCount', 'totalRating', 'likes', 'viewCount']) ||
        request.auth.token.email == 'kermit.tam@gmail.com'
      );
      allow delete: if request.auth != null &&
        request.auth.token.email == 'kermit.tam@gmail.com';
    }
    
    // Artists collection
    match /artists/{artistId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.uid == userId || request.auth.token.email == 'kermit.tam@gmail.com');
    }
    
    // Comments collection
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // TabRequests collection
    match /tabRequests/{requestId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    
    // System Playlists collection
    match /playlists/{playlistId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Page Views collection
    match /pageViews/{viewId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if false;
    }
    
    // Daily Stats collection
    match /dailyStats/{dateId} {
      allow read: if request.auth != null && 
        request.auth.token.email == 'kermit.tam@gmail.com';
      allow write: if request.auth != null && 
        request.auth.token.email == 'kermit.tam@gmail.com';
    }
    
    // Recent Views collection
    match /recentViews/{docId} {
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
  }
}
