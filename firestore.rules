rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'kermit.tam@gmail.com',
          'showroomchan@gmail.com'
        ];
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // 登入用戶嘅 penName 與樂譜 uploaderPenName 一致時可編輯／刪除（與 createdBy 並列）
    function tabEditableByUploaderPenName() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(['penName'])
        && resource.data.keys().hasAny(['uploaderPenName'])
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.penName is string
        && resource.data.uploaderPenName is string
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.penName == resource.data.uploaderPenName
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.penName.size() > 0;
    }

    // ==================== Tabs ====================
    match /tabs/{tabId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.uploaderId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        tabEditableByUploaderPenName() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['averageRating', 'ratingCount', 'totalRating', 'likes', 'viewCount'])
      );
      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.uploaderId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        tabEditableByUploaderPenName()
      );
    }

    // ==================== Artists ====================
    match /artists/{artistId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isSuperAdmin() || resource.data.createdBy == request.auth.uid
      );
      allow delete: if isSuperAdmin();
    }

    // ==================== Users ====================
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isOwner(userId) || isSuperAdmin());
      allow update: if isAuthenticated() && (
        isOwner(userId) ||
        isSuperAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount']) && request.resource.data.followerCount is int)
      );
      allow delete: if isAuthenticated() && (isOwner(userId) || isSuperAdmin());
    }
    // 追蹤：任何人可讀；只有登入用戶可為自己加/刪 followers 紀錄
    match /users/{userId}/followers/{followerId} {
      allow read: if true;
      allow create: if isAuthenticated() && followerId == request.auth.uid;
      allow delete: if isAuthenticated() && followerId == request.auth.uid;
      allow update: if false;
    }

    // ==================== Comments ====================
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (isOwner(resource.data.userId) || isSuperAdmin());
    }

    // ==================== Tab Requests ====================
    match /tabRequests/{requestId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount', 'voters', 'status', 'fulfilledBy', 'fulfilledAt'])
        || isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ==================== Playlists ====================
    match /playlists/{playlistId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isSuperAdmin());
      allow delete: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isSuperAdmin());
    }

    // ==================== User Playlists ====================
    match /userPlaylists/{playlistId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    // ==================== Settings ====================
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ==================== Page Views ====================
    match /pageViews/{viewId} {
      allow create: if true;
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    // ==================== Daily Stats ====================
    match /dailyStats/{dateId} {
      allow read, write: if isAuthenticated() && isSuperAdmin();
    }

    // ==================== Recent Views ====================
    match /recentViews/{docId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    // ==================== Ratings ====================
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    // ==================== Saved Artists (已收藏歌手) ====================
    match /userSavedArtists/{docId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ==================== Saved Playlists (已收藏歌單) ====================
    match /userSavedPlaylists/{docId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ==================== Liked Songs ====================
    match /userLikedSongs/{docId} {
      // 讀：文件唔存在時 getDoc 都要通過（resource == null）；存在時只准讀自己
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ==================== Admins ====================
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ==================== User Library Cache (denormalised read-view for /library page) ====================
    match /userLibraryCache/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if isAuthenticated() && isOwner(userId);
    }

    // ==================== Cache (homePage, searchData, allTabs, playlist_*, artistPage_*, tabRequestsList) ====================
    // Read: anyone. Write: Admin SDK only. Delete: super admin only (manual "clear artist page cache" from client).
    match /cache/{docId} {
      allow read: if true;
      allow create, update: if false;
      allow delete: if isSuperAdmin();
    }

  }
}
