# Firebase Configuration
# 請將以下配置替換為你嘅 Firebase 項目設定
# 去 Firebase Console -> 項目設定 -> 一般 -> 你的應用程式 -> SDK 設定和配置

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# YouTube Data API v3
# 用於內嵌 YouTube 搜尋功能
# 去 Google Cloud Console -> APIs & Services -> Credentials -> Create API Key
# 並啟用 YouTube Data API v3
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key_here

# Admin API Key
# 用於觸發自動更新等管理功能
# 設定一個強密碼，例如：openssl rand -base64 32
ADMIN_API_KEY=your_secure_random_key_here

# 分類封面自動更新密鑰
# 用於觸發更新首頁歌手分類封面（男歌手/女歌手/組合）
UPDATE_CATEGORY_KEY=your_update_key_here
